APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

ODDS_API_KEY=your_odds_api_key_here
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
ODDS_API_TIMEOUT=30
ODDS_API_CACHE_ODDS_TTL=300
ODDS_API_CACHE_EVENTS_TTL=1800
ODDS_API_FALLBACK_ENABLED=true

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000,https://yourdomain.com

# WNBA season and source-of-truth feeds for the 2026-27 season.
# SportsBlaze season year is the start year from /seasons/wnba (e.g. 2026 → "2026-2027").
WNBA_CURRENT_SEASON=2026
WNBA_CURRENT_SEASON_LABEL=2026-2027
WNBA_DATA_PROVIDER=sportsblaze
SPORTSBLAZE_API_KEY=
SPORTSBLAZE_WNBA_BASE_URL=https://api.sportsblaze.com
SPORTSBLAZE_CACHE_BASE_URL=https://cache.sportsblaze.com
SPORTSBLAZE_LEAGUE_ID=wnba

# Optional v1 feed overrides (see docs.sportsblaze.com/wnba/core_endpoints).
# Defaults: wnba/v1/schedule/season/{year}.json and per-game wnba/v1/boxscores/game/{id}.json
SPORTSBLAZE_WNBA_PLAYER_BOXSCORES_URL=
SPORTSBLAZE_WNBA_TEAM_BOXSCORES_URL=
SPORTSBLAZE_WNBA_SCHEDULE_URL=
SPORTSBLAZE_WNBA_PLAY_BY_PLAY_URL=
WNBA_FALLBACK_TO_SPORTSDATAVERSE=false
