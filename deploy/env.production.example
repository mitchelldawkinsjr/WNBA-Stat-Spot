# Copy to the deploy directory on the VPS as `.env` (next to docker-compose.prod.yml).
# Generate APP_KEY: docker compose -f docker-compose.prod.yml run --rm app php artisan key:generate --show

APP_NAME="WNBA Stat Spot"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://wnba-stat-spot.example.com
LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=wnba_stat_spot
DB_USERNAME=wnba
DB_PASSWORD=change_me_strong_password
# Internal Docker Postgres has no TLS; Laravel defaults to sslmode=require in config/database.php
DB_SSLMODE=disable

SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database

FILESYSTEM_DISK=local

CORS_ALLOWED_ORIGINS=https://wnba-stat-spot.example.com

VITE_APP_NAME="${APP_NAME}"

WNBA_CURRENT_SEASON=2026
WNBA_CURRENT_SEASON_LABEL=2026-2027
WNBA_INCREMENTAL_PROVIDER=espn
WNBA_GAMELOG_PROVIDER=espn

# App-specific (fill from .env.example / secrets)
ODDS_API_KEY=
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
