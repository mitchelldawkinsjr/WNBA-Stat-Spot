{
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "healthcheckPath": "/api/status",
    "healthcheckTimeout": 30
  },
  "environments": {
    "production": {
      "variables": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "PORT": "${{RAILWAY_PORT}}",
        "APP_URL": "https://${{RAILWAY_PUBLIC_DOMAIN}}",

        "DB_CONNECTION": "pgsql",
        "DATABASE_URL": "postgresql://postgres.[project-ref]:[password]@aws-0-us-east-2.pooler.supabase.com:6543/postgres?sslmode=require",
        "DB_HOST": "aws-0-us-east-2.pooler.supabase.com",
        "DB_PORT": "6543",
        "DB_DATABASE": "postgres",
        "DB_USERNAME": "postgres.[project-ref]",
        "DB_PASSWORD": "[your-supabase-password]",
        "DB_SSLMODE": "require",
        "PGSSLMODE": "require",

        "REDIS_URL": "rediss://default:[token]@[endpoint]:6379",
        "REDIS_HOST": "[your-upstash-host]",
        "REDIS_PORT": "6379",
        "REDIS_PASSWORD": "[your-upstash-password]",

        "CACHE_DRIVER": "redis",
        "QUEUE_CONNECTION": "redis",
        "SESSION_DRIVER": "redis",

        "WNBA_CACHE_ENABLED": "true",
        "WNBA_CACHE_TTL": "3600",
        "WNBA_CURRENT_SEASON": "2025",
        "WNBA_LOGGING_ENABLED": "true",
        "WNBA_LOG_LEVEL": "info"
      }
    }
  }
}
